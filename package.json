{
  "name": "badminton-court-manager",
  "private": true,
  "version": "0.0.0",
  "description": "📸 Snap, 🎲 Shuffle, 🏸 Play! The badminton organizer app that turns chaos into fair, fun matches. Upload your player list photo or add them manually to get perfectly balanced teams in seconds.",
  "type": "module",
  "homepage": "https://sylhare.github.io/Badminton",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && cp ./dist/index.html ./dist/404.html",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 10",
    "lint:fix": "eslint . --report-unused-disable-directives --max-warnings 10 --fix",
    "preview": "vite preview",
    "test": "vitest --run",
    "test:coverage": "vitest --run --coverage",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "remove-comments": "npx tsx script/remove_comments.ts src tests e2e",
    "prerender-notebooks": "npx tsx script/prerender-notebooks.ts"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "@techstark/opencv-js": "^4.11.0-release.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@playwright/test": "~1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^28.1.0",
    "playwright": "~1.58.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "esbuild": "0.25.5"
  }
}
